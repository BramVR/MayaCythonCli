{
  "distribution_name": "maya-tool",
  "package_name": "maya_tool",
  "package_dir": "src/maya_tool",
  "version": "0.1.0",
  "compiled_modules": [
    "_cy_logic"
  ],
  "package_data": [
    "*.json"
  ],
  "smoke": {
    "callable": "show_ui",
    "compiled_modules": [
      "_cy_logic"
    ],
    "resource_check": "tool_manifest.json"
  },
  "default_target": "windows-2025",
  "targets": {
    "windows-2025": {
      "platform": "windows",
      "module_name": "MayaTool",
      "maya_version": "2025"
    }
  }
}
